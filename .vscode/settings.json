{
  "cmake.configureOnOpen": true,
  "cmake.buildDirectory": "${workspaceFolder}/build",
  "cmake.exportCompileCommandsFile": true,

  "C_Cpp.default.compileCommands": "${workspaceFolder}/build/compile_commands.json",
  "C_Cpp.default.compilerPath": "/opt/cross/bin/i686-elf-gcc",
  "C_Cpp.default.intelliSenseMode": "gcc-x86",
  "C_Cpp.default.cStandard": "c17",
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/include",
    "${workspaceFolder}/include/**",
    "${workspaceFolder}/src",
    "${workspaceFolder}/src/**",
    "/opt/cross/lib/gcc/i686-elf/**",
    "/opt/cross/i686-elf/include/**"
  ],
  "C_Cpp.default.browse.path": [
    "${workspaceFolder}/include/**",
    "${workspaceFolder}/src/**"
  ],
  "C_Cpp.default.browse.databaseFilename": "/home/vscode/.cache/vscode-cpptools/arkoi_os/.browse.VC.db",
  "C_Cpp.default.browse.limitSymbolsToIncludedHeaders": false,
  "C_Cpp.workspaceParsingPriority": "high",

  "C_Cpp.intelliSenseEngine": "default",
  "C_Cpp.autocomplete": "default",

  "files.associations": {
    "*.h": "c"
  },

  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true
  },
  "editor.suggestOnTriggerCharacters": true,
  "editor.suggest.showFiles": true,
  "editor.suggest.showWords": true,

  "[c]": {
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    },
    "editor.suggestOnTriggerCharacters": true,
    "editor.suggest.showFiles": true
  },

  "[cpp]": {
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    },
    "editor.suggestOnTriggerCharacters": true,
    "editor.suggest.showFiles": true
  }
}
