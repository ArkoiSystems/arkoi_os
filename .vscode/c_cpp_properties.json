{
  "version": 4,
  "configurations": [
    {
      "name": "ArkoiOS",
      "compilerPath": "/opt/cross/bin/i686-elf-gcc",
      "intelliSenseMode": "gcc-x86",
      "cStandard": "c17",
      "compileCommands": "${workspaceFolder}/build/compile_commands.json",
      "includePath": [
        "${workspaceFolder}/include",
        "${workspaceFolder}/include/**",
        "${workspaceFolder}/src",
        "${workspaceFolder}/src/**",
        "/opt/cross/lib/gcc/i686-elf/**",
        "/opt/cross/i686-elf/include/**"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}/include/**",
          "${workspaceFolder}/src/**"
        ],
        "databaseFilename": "/home/vscode/.cache/vscode-cpptools/arkoi_os/.browse.VC.db",
        "limitSymbolsToIncludedHeaders": false
      }
    }
  ]
}
