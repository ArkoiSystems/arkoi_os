{
  "name": "ArkoiOS i686-elf DevContainer",

  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  "remoteUser": "vscode",

  // Ports (QEMU VNC)
  "forwardPorts": [5901, 1234],
  "portsAttributes": {
    "5901": {
      "label": "QEMU VNC",
      "onAutoForward": "notify"
    },
    "1234": {
      "label": "GDB",
      "onAutoForward": "notify"
    }
  },

  // Environment
  "containerEnv": {
    "TOOLS": "/opt/cross",
    "CC": "i686-elf-gcc",
    "CXX": "i686-elf-g++",
    "AS": "i686-elf-as",
    "AR": "i686-elf-ar",
    "OBJCOPY": "i686-elf-objcopy",
    "OBJDUMP": "i686-elf-objdump",
    "GDB": "i686-elf-gdb"
  },

  // Debugging support
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp=unconfined"
  ],

  // Persistent ccache
  "mounts": [
    "source=ccache,target=/home/vscode/.cache/ccache,type=volume"
  ],

  // VS Code setup
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "twxs.cmake",
        "ms-vscode.hexeditor"
      ],
      "settings": {
        "C_Cpp.default.compilerPath": "/opt/cross/bin/i686-elf-gcc",
        "C_Cpp.default.intelliSenseMode": "gcc-x86",
        "C_Cpp.default.includePath": [
          "/opt/cross/lib/gcc/i686-elf/**",
          "/opt/cross/i686-elf/include/**"
        ]
      }
    }
  },

  // Sanity check after build
  "postCreateCommand": "i686-elf-gcc --version && i686-elf-as --version && i686-elf-g++ --version",

  // Default workspace
  "workspaceFolder": "/workspace"
}